{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "globalEnv": ["CI", "GITHUB_TOKEN", "NODE_ENV", "PORT"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "jest": {
      "inputs": ["src/**/*.js"]
    },
    "playwright": {
      "dependsOn": ["build"],
      "inputs": ["src/**/*.js"]
    },
    "test": {
      "dependsOn": ["build"],
      "inputs": ["src/**/*.js"]
    },
    "lint:check": {},
    "lint": {},
    "dev": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    }
  }
}
