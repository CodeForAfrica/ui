    "ALLOWED_EMAILS",
    "API_SECRET_KEY",
    "APP_SLUG",
    "APP_URL",
    "CI",
    "DATABASE_URL",
    "DEFAULT_LOCALE",
    "ENABLE_HSTS",
    "GITHUB_TOKEN",
    "GOOGLE_API_KEY",
    "GOOGLE_CLIENT_SECRET",
    "GOOGLE_ID",
    "GOOGLE_SECRET",
    "HURUMAP_API_URL",
