    "WORDPRESS_APPLICATION_USERNAME",
    "WORDPRESS_MULTISITE_PREFIX",
    "WORDPRESS_PREVIEW_SECRET",
    "WORDPRESS_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "jest": {
      "inputs": ["src/**/*.js"]
    },
    "playwright": {
      "dependsOn": ["build"],
      "inputs": ["src/**/*.js"]
    },
    "test": {
      "dependsOn": ["build"],
      "inputs": ["src/**/*.js"]
    },
    "lint:check": {},
    "lint": {},
    "dev": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    }
  }
}
