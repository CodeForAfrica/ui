# Args and Envs
MIGRATIONS_DIR=./migrations

APP_NAME=TrustLab
APP_URL=http://localhost:3000
IMAGE_UNOPTIMIZED="true"
SEO_DISABLED="true"

DEFAULT_LOCALE=en
LOCALES="en"

NEXT_TELEMETRY_DISABLED=1

# Secrets
## Optional - App will work fine without these but must be
#             declared for docker image to build
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
SMTP_PASS=
