function getParentUrl(parentPage) {
  if (!parentPage) {
    return null;
  }

  const { slug, breadcrumbs } = parentPage;
  if (!breadcrumbs?.length) {
    return `/${slug}`;
  }
  return breadcrumbs[breadcrumbs.length - 1].url;
}

function getPageUrl(slug, parentPage) {
  let url = null;
  if (parentPage) {
    const parentUrl = getParentUrl(parentPage);
    if (parentUrl) {
      url = `${parentUrl}/${slug}`;
    }
  }
  return url;
}

export default getPageUrl;
