{
  "extends": ["//"],
  "tasks": {
    "build": {
      "dependsOn": ["build-next", "build-payload"]
    },
    "build-next": {
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "NEXT_PUBLIC_APP_LOGO_URL",
        "NEXT_PUBLIC_APP_NAME",
        "NEXT_PUBLIC_APP_URL",
        "NEXT_PUBLIC_IMAGE_DOMAINS",
        "NEXT_PUBLIC_IMAGE_UNOPTIMIZED",
        "NEXT_PUBLIC_SENTRY_DSN",
        "NEXT_PUBLIC_VERCEL_ENV",
        "NEXT_PUBLIC_VERCEL_URL",
        "NEXT_RUNTIME",
        "GOOGLE_API_KEY",
        "PAYLOAD_PUBLIC_APP_URL",
        "PAYLOAD_PUBLIC_DEFAULT_LOCALE",
        "PAYLOAD_PUBLIC_LOCALES",
        "PROJECT_ROOT",
        "SENTRY_AUTH_TOKEN",
        "SENTRY_ORG",
        "SENTRY_PROJECT"
      ]
    },
    "build-payload": {
      "outputs": ["build/**"],
      "env": [
        "MIGRATIONS_DIR",
        "MONGO_URL",
        "NEXT_BUILD",
        "NEXT_HOSTNAME",
        "NEXT_PUBLIC_SENTRY_DSN",
        "NEXT_MANUAL_SIG_HANDLE",
        "PAYLOAD_CORS",
        "PAYLOAD_CSRF",
        "PAYLOAD_PUBLIC_APP_URL",
        "PAYLOAD_PUBLIC_DEFAULT_LOCALE",
        "PAYLOAD_PUBLIC_LOCALES",
        "PAYLOAD_SECRET",
        "S3_ACCESS_KEY_ID",
        "S3_BUCKET",
        "S3_SECRET_ACCESS_KEY",
        "S3_REGION",
        "SENDGRID_API_KEY",
        "SENDGRID_FROM_EMAIL",
        "SENDGRID_FROM_NAME",
        "SMTP_FROM_ADDRESS",
        "SMTP_FROM_NAME",
        "SMTP_HOST",
        "SMTP_PASS",
        "SMTP_PORT",
        "SMTP_USER"
      ]
    }
  }
}
